# 🔐 Secrets - DO NOT COMMIT!

# Personal secrets file
secrets.nix

# Encrypted secrets
*.age
*.enc
*.gpg

# Key files
*.key
*.pem
*.pub

# Backup files
*.backup
*.bak

# Temporary files
/tmp/
temp/

# Password files
passwords.txt
secrets.txt

# Configuration files with secrets
config.json
.env
.env.*

# SSH keys (references only)
ssh/
*.ssh

# Certificates
*.crt
*.cert
*.p12
*.pfx

# Database files
*.db
*.sqlite

# Log files with sensitive data
*.log

# Secret management tools
.sops.yaml
.age.yml

# Any file that might contain secrets
!default.nix
!README.md
!.gitignore
